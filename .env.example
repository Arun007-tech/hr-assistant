# Copy to .env.local for development; set the same variables in Vercel for production.

# Login passphrase for the single-user PIN gate. Use something long, not 4 digits.
APP_PIN=

# Secret for signing the session cookie. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Google AI Studio key (aistudio.google.com -> Get API key). Not Vertex AI.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Supabase -> Project Settings -> API. Use the service_role key (server-only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
